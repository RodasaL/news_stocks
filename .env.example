# Backend API Configuration

# GOOGLE GEMINI API (optional - for intelligent asset classification & ETF analysis)
# Free tier available at: https://ai.google.dev
# Setup: https://ai.google.dev/gemini-api/docs/quickstart
#
# ⚠️  FREE TIER LIMITS (as of May 2026):
#  - Rate Limit: 2 requests/minute (RPM) for Gemini 2.5 Flash
#  - Daily Limit: 250 requests per day per project
#  - No Context Caching: Advanced caching features unavailable
#  - Data Policy: Your data may be used to improve Google products
#  - Billing: Project must have NO billing account to stay on free tier
#
# Get your API key and set it below for asset classification:
GEMINI_API_KEY=your_api_key_here

# FREE NEWS SOURCES (no API key needed):
# 1. Google News RSS - https://news.google.com/rss/search
# 2. Yahoo Finance RSS - https://feeds.finance.yahoo.com
# 3. MarketWatch RSS - https://feeds.marketwatch.com
# 4. Reddit r/stocks & r/investing - https://reddit.com/r/stocks/new.json

# OPTIONAL: Add API keys for additional/premium sources:
# ALPHA_VANTAGE_KEY=your_key_here   (5 calls/min free tier) - https://www.alphavantage.co
# FINNHUB_KEY=your_key_here         (60 calls/min free tier) - https://finnhub.io
# NEWSAPI_KEY=your_key_here         (100/day free tier) - https://newsapi.org

# Frontend Configuration
VITE_API_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO
